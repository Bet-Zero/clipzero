{
  "name": "clipzero",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "start:web": "npm run start -w apps/web",
    "start:api": "npm run start -w apps/api",
    "lint:web": "npm run lint -w apps/web",
    "test:api": "npm run test -w apps/api",
    "test:web": "npm run test -w apps/web",
    "test": "npm run test:api && npm run test:web",
    "test:e2e": "npm run test:e2e -w apps/web"
  }
}
